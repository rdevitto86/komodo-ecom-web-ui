{
  "name": "komodo-desktop-svelte",
  "version": "1.0.0",
  "private": true,
  "description": "Modern ecommerce website",
  "homepage": "./",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:mock": "vite dev --mode mock",
    "build": "vite build",
    "build:demo": "vite build --mode mock",
    "preview": "vite preview",
    "lint": "oxlint",
    "test": "bun run test:unit && bun run test:e2e",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "up": "bun update --latest",
    "clean": "bunx rimraf .svelte-kit dist build node_modules",
    "fresh": "bun run clean && bun install --linker=isolated",
    "gen:types": "bun run scripts/gen-types.ts",
    "preinstall": "npx only-allow bun",
    "prepare": "svelte-kit sync"
  },
  "dependencies": {
    "@sveltejs/kit": "2.65.2",
    "@tailwindcss/vite": "4.3.1",
    "@threlte/core": "8.5.16",
    "@threlte/extras": "9.21.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "gsap": "3.15.0",
    "komodo-forge-sdk-ts": "github:rdevitto86/komodo-forge-sdk-ts",
    "lenis": "1.3.23",
    "lucide-svelte": "1.0.1",
    "postprocessing": "6.39.1",
    "svelte": "5.56.3",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "three": "0.184.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@sveltejs/adapter-node": "5.5.4",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/svelte": "5.3.1",
    "@types/node": "25.9.3",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "jsdom": "29.1.1",
    "oxlint": "1.70.0",
    "openapi-typescript": "7.13.0",
    "svelte-check": "4.6.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=26",
    "bun": ">=1.2.0"
  }
}